@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ExperiencePage>
@{
    Layout = "master.cshtml";
    var bannerMain = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("experienceImg")?.Url();
    var imgPool = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("poolImg")?.Url();
    var imgPlayground = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("playgroundImg")?.Url();
    var imgSpa = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("spaImg")?.Url();
}

<div class="relative w-full h-[60vh] overflow-hidden">
    <img src="@bannerMain" class="w-full h-full object-cover" alt="Boma Banner">
    <div class="absolute inset-0 bg-black/30 flex flex-col items-center justify-center text-white text-center px-4">
        <div class="text-xs tracking-[0.3em] uppercase font-light mb-2">Boma Experiences</div>
        <p class="text-xs md:text-sm tracking-widest uppercase font-light opacity-75">
            Trang chủ » Trải nghiệm
        </p>
    </div>
</div>

<section class="max-w-4xl mx-auto px-6 py-20 text-center font-sans text-slate-700">
    <div class="text-xs tracking-[0.2em] uppercase text-amber-700 font-medium mb-3">
        Khám phá Boma
    </div>
    <h2 class="text-3xl font-serif font-light uppercase tracking-wider text-slate-800 mb-8">
        Trải Nghiệm
    </h2>
    <div class="prose prose-slate max-w-none leading-loose text-justify md:text-center text-slate-600 font-light space-y-4">
        @Html.Raw(Model.Value("experienceDescription"))
    </div>
</section>

<section class="max-w-6xl mx-auto px-6 pb-24 font-sans text-slate-700">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <div class="flex flex-col bg-white border border-slate-100 shadow-sm rounded-sm overflow-hidden group">
            <div class="h-64 overflow-hidden relative">
                <img src="@imgPool" class="w-full h-full object-cover group-hover:scale-105 transition duration-700" alt="Hồ bơi" />
            </div>
            <div class="p-6 flex flex-col justify-between flex-grow">
                <div class="prose prose-sm text-slate-600 leading-relaxed">
                    @Html.Raw(Model.Value("pool"))
                </div>
                <div class="text-xs uppercase tracking-widest text-amber-700 font-medium group-hover:underline mt-6">
                    Khám phá ngay →
                </div>
            </div>
        </div>

        <div class="flex flex-col bg-white border border-slate-100 shadow-sm rounded-sm overflow-hidden group">
            <div class="h-64 overflow-hidden relative">
                <img src="@imgPlayground" class="w-full h-full object-cover group-hover:scale-105 transition duration-700" alt="Khu vui chơi trẻ em" />
            </div>
            <div class="p-6 flex flex-col justify-between flex-grow">
                <div class="prose prose-sm text-slate-600 leading-relaxed">
                    @Html.Raw(Model.Value("playground"))
                </div>
                <div class="text-xs uppercase tracking-widest text-amber-700 font-medium group-hover:underline mt-6">
                    Khám phá ngay →
                </div>
            </div>
        </div>

        <div class="flex flex-col bg-white border border-slate-100 shadow-sm rounded-sm overflow-hidden group">
            <div class="h-64 overflow-hidden relative">
                <img src="@imgSpa" class="w-full h-full object-cover group-hover:scale-105 transition duration-700" alt="Spa" />
            </div>
            <div class="p-6 flex flex-col justify-between flex-grow">
                <div class="prose prose-sm text-slate-600 leading-relaxed">
                    @Html.Raw(Model.Value("spa"))
                </div>
                <div class="text-xs uppercase tracking-widest text-amber-700 font-medium group-hover:underline mt-6">
                    Khám phá ngay →
                </div>
            </div>
        </div>
    </div>
</section>