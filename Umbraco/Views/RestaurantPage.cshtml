@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.RestaurantPage>
@{
    Layout = "master.cshtml";
    var imgBanner = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("restaurantBanner")?.Url();
    var imgSmallLogo = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("smallLogo")?.Url();
    var imgBomaPax = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("bomaPax")?.Url();
    var imgReservation = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("reservationImg")?.Url();
    var imgDining = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("diningImg")?.Url();
    var imgViewNight = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("restaurantView")?.Url();
}

<div class="relative w-full h-[60vh] md:h-[80vh] overflow-hidden">
    <img src="@imgBanner" class="w-full h-full object-cover" alt="Boma Restaurant Banner">
    <div class="absolute inset-0 bg-black/20 flex flex-col items-center justify-center text-white text-center px-4">
        <div class="text-xs md:text-sm tracking-[0.3em] uppercase font-light mb-2">Boma Dining</div>
        <p class="text-xs md:text-sm tracking-widest uppercase font-light opacity-75">
            Trang chủ » Nhà hàng
        </p>
    </div>
</div>

<section class="max-w-4xl mx-auto px-6 py-16 text-center font-sans text-slate-700">
    @if (imgSmallLogo != null)
    {
        <img src="@imgSmallLogo" class="mx-auto h-12 w-auto mb-6 opacity-80" alt="Boma Decoration Logo" />
    }
    <div class="prose prose-slate max-w-none text-xl md:text-3xl text-center uppercase tracking-[0.15em] text-slate-800 font-light">
        @Html.Raw(Model.Value("restaurantTitle"))
    </div>
</section>

<section class="max-w-6xl mx-auto px-6 py-12 font-sans text-slate-700">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="prose prose-slate max-w-none text-justify text-slate-600 leading-loose">
            @Html.Raw(Model.Value("restaurantDescription"))
        </div>
        <div class="w-full h-[50vh] overflow-hidden rounded-sm shadow-sm">
            <img src="@imgBomaPax" class="w-full h-full object-cover" alt="Boma Beach Club">
        </div>
    </div>
</section>

<div class="w-full bg-[#f4f3ee] py-20 my-16 border-t border-b border-slate-200/50">
    <section class="max-w-6xl mx-auto px-6 font-sans text-slate-700">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="w-full h-[50vh] overflow-hidden rounded-sm shadow-sm lg:order-1 order-2">
                <img src="@imgReservation" class="w-full h-full object-cover" alt="Reservation Space">
            </div>
            <div class="prose prose-slate max-w-none text-justify lg:order-2 order-1 bg-white p-8 border border-slate-200/60 shadow-sm rounded-sm">
                @Html.Raw(Model.Value("description"))
            </div>
        </div>
    </section>
</div>

<section class="max-w-6xl mx-auto px-6 py-12 font-sans text-slate-700">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
        <div class="lg:col-span-2 w-full h-[55vh] overflow-hidden rounded-sm shadow-sm">
            <img src="@imgDining" class="w-full h-full object-cover" alt="Romantic Dining Under the Stars">
        </div>
        <div class="bg-white p-6 border border-slate-100 shadow-sm rounded-sm prose prose-sm max-w-none leading-relaxed text-slate-600">
            @Html.Raw(Model.Value("paxDescription"))
        </div>
    </div>
</section>

@if (imgViewNight != null)
{
    <section class="max-w-6xl mx-auto px-6 pt-12 pb-24 font-sans">
        <div class="w-full h-[45vh] md:h-[60vh] overflow-hidden rounded-sm shadow-sm group">
            <img src="@imgViewNight" class="w-full h-full object-cover group-hover:scale-102 transition duration-700" alt="Boma Beach Club By Night">
        </div>
    </section>
}