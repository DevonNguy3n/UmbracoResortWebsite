@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.WeddingPage>
@{
    Layout = "master.cshtml";
    var bannerMain = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("weddingBanner")?.Url();
    var bannerService = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("serviceBanner")?.Url();
    var imgService = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("serviceImg")?.Url();
    var imgOffer = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("offerImg")?.Url();
}

<div class="relative w-full h-[60vh] md:h-[80vh] overflow-hidden">
    <img src="@bannerMain" class="w-full h-full object-cover" alt="Boma Wedding Banner">
    <div class="absolute inset-0 bg-black/20 flex flex-col items-center justify-center text-white text-center px-4">
        <p class="text-xs md:text-sm tracking-[0.3em] uppercase font-light mb-2">Boma Wedding</p>
        <p class="text-xs md:text-sm tracking-widest uppercase font-light opacity-70">Trang chủ » Wedding</p>
    </div>
</div>

<section class="max-w-4xl mx-auto px-6 py-20 text-center font-sans text-slate-700">
    <div class="prose prose-slate max-w-none leading-loose text-justify md:text-center text-slate-600 font-light text-base space-y-4">
        @Html.Raw(Model.Value("weddingTitle"))
    </div>
</section>

<section class="max-w-6xl mx-auto px-6 py-12 font-sans text-slate-700">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="prose prose-slate max-w-none text-justify text-slate-600 leading-loose">
            @Html.Raw(Model.Value("serviceDescription"))
        </div>
        <div class="w-full h-[50vh] overflow-hidden rounded-sm shadow-sm">
            <img src="@bannerService" class="w-full h-full object-cover" alt="Timeless Moments">
        </div>
    </div>
</section>

<div class="w-full bg-[#f4f3ee] py-20 my-16 border-t border-b border-slate-200/50">
    <section class="max-w-6xl mx-auto px-6 font-sans text-slate-700">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-center">
            <div class="lg:col-span-2 prose prose-slate max-w-none text-justify text-slate-600 leading-loose">
                @Html.Raw(Model.Value("serveice"))
            </div>
            <div class="w-full h-[60vh] overflow-hidden rounded-sm shadow-sm">
                <img src="@imgService" class="w-full h-full object-cover" alt="Wedding Packages">
            </div>
        </div>
    </section>
</div>

<section class="max-w-6xl mx-auto px-6 py-12 mb-20 font-sans text-slate-700">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="w-full h-[55vh] overflow-hidden rounded-sm shadow-sm">
            <img src="@imgOffer" class="w-full h-full object-cover" alt="Pre-Wedding Offer">
        </div>
        <div class="bg-white p-8 border border-slate-100 shadow-sm rounded-sm prose prose-slate max-w-none leading-loose">
            @Html.Raw(Model.Value("offerDes"))
            <a href="/contactpage" class="w-full block text-center mt-8 bg-amber-700 hover:bg-amber-800 text-white text-xs tracking-widest uppercase font-medium py-4 transition duration-300 rounded-sm">
                Đặt lịch tư vấn ngay
            </a>
        </div>
    </div>
</section>