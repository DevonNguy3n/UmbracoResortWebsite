@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>
@{
    Layout = "master.cshtml";
    var allRooms = Model.Parent.Children();
    var mainImage = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("roomImage")?.Url();
}

<div class="max-w-6xl mx-auto px-6 py-20 font-sans text-slate-700">
    <h1 class="text-4xl text-center uppercase tracking-widest mb-10 text-slate-800">
        @Model.Name
    </h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-6">
            <img src="@mainImage" class="w-full h-[50vh] object-cover" />
            <div class="prose max-w-none leading-loose text-justify text-slate-600">
                @Html.Raw(Model.Value("roomDescription"))
            </div>
        </div>

        <div class="bg-[#f4f3ee] p-8 border border-slate-200 h-fit">
            <h2 class="text-lg font-medium uppercase tracking-wider text-slate-800 mb-4 border-b border-slate-300 pb-2">
                Thông tin phòng
            </h2>
            <ul class="space-y-3 text-sm mb-6">
                <li><strong>Diện tích:</strong> @Model.Value("size")</li>
                <li><strong>Loại giường:</strong> @Model.Value("bedType")</li>
                <li><strong>Tầm nhìn:</strong> @Model.Value("view")</li>
            </ul>

            <h3 class="text-sm font-medium uppercase tracking-wider text-slate-800 mb-2">
                Tiện ích phòng:
            </h3>
            <div class="bg-white p-4 border border-slate-100 prose prose-sm text-slate-600">
                @Html.Raw(Model.Value("roomAmenities"))
            </div>
        </div>
        <a href="/bookingpage/" class="w-full block text-center mt-8 bg-amber-700 hover:bg-amber-800 text-white text-xs tracking-widest uppercase font-medium py-4 transition duration-300 rounded-sm">
            Đặt phòng ngay ➣
        </a>
    </div>
</div>

<hr class="max-w-6xl mx-auto my-8 border-slate-200" />

<section class="max-w-6xl mx-auto px-6 pb-24">
    <h2 class="text-3xl text-center uppercase tracking-widest mb-12 text-slate-800">
        Các Phòng Khác
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        @{ int count = 0; }
        @foreach (var otherRoom in allRooms)
        {
            if (otherRoom.Id == Model.Id || count >= 6) { continue; }
            count++;

            var rImage = otherRoom.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("roomImage")?.Url();

            <a href="@otherRoom.Url()" class="flex flex-col bg-white border border-slate-100 shadow-sm hover:shadow-md transition group">
                <div class="h-52 overflow-hidden">
                    <img src="@rImage" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                </div>
                <div class="p-6">
                    <h3 class="text-base font-medium uppercase tracking-wider text-slate-800 group-hover:text-amber-700 transition-colors">
                        @otherRoom.Name
                    </h3>
                    <div class="text-xs uppercase text-amber-700 font-medium mt-4">
                        Xem chi tiết
                    </div>
                </div>
            </a>
        }
    </div>
</section>